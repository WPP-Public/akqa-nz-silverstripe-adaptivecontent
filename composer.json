{
    "name": "heyday/silverstripe-adaptivecontent",
    "description": "SilverStripe Adaptive Content",
    "type": "silverstripe-vendormodule",
    "license": "MIT",
    "require": {
        "silverstripe/framework": "^5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9"
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Heyday\\AdaptiveContent\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "4.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    }
}
